generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  
  plan          String    @default("FREE") // FREE, PRO, LIFETIME
  planExpiresAt DateTime?
  brandName     String?
  brandLogoUrl  String?
  brandColor    String?
  instapayUrl        String?
  vodafoneCashNumber String?
  defaultInvoiceStyle Json?
  role          String    @default("USER") // USER, ADMIN

  accounts      Account[]
  sessions      Session[]
  invoices      Invoice[]
  payments      Payment[]
}

model AppSettings {
  id                     String  @id
  ownerInstapayUrl       String?
  ownerVodafoneCashNumber String?
  pricing                Json?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invoice {
  id            String   @id @default(cuid())
  userId        String
  invoiceNumber String
  clientName    String
  clientEmail   String?
  issueDate     DateTime
  dueDate       DateTime
  currency      String   @default("EGP")
  subtotal      Float
  tax           Float    @default(0)
  total         Float
  notes         String?  @db.Text
  items         Json
  template      String   @default("minimal")
  style         Json?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  method        String   // PAYPAL, INSTAPAY, VODAFONE
  product       String?  // PRO_MONTHLY, PRO_YEARLY, LIFETIME
  amount        Float
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  screenshotUrl String?
  paypalOrderId String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PromoCode {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   @default("PRO") // TRIAL, PRO
  product     String?  // PRO_MONTHLY, PRO_YEARLY, LIFETIME
  duration    Int?     // Duration in days, null for lifetime or simple Pro upgrade
  maxUses     Int      @default(1)
  currentUses Int      @default(0)
  expiresAt   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
